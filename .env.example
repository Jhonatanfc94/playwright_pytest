# =============================================
# 🔐 Variables de Entorno — playwright_pytest
# =============================================
# Copia este archivo como .env y llena los valores.
# NUNCA commitees el archivo .env al repositorio.

# URLs del sitio a testear
BASE_URL=https://your-site.com

# API (si aplica)
API_BASE_URL=

# Credenciales de test (si necesitas login en sitios)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Email testing (Gmail App Password para verificación)
EMAIL_APP_PASSWORD=

# Browser config para CI
HEADLESS=false
